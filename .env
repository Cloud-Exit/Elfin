# Elfin Configuration

# llama.cpp chat model (GGUF file in data/models/)
# Pick the right quant for your hardware:
#   8 GB RAM:  gemma-4-E4B-it-Q3_K_M.gguf
#   16-32 GB:  gemma-4-E4B-it-Q5_K_M.gguf   (default — our RK1 is 16 GB)
#   32 GB+:    gemma-4-E4B-it-UD-Q8_K_XL.gguf
CHAT_MODEL=gemma-4-E4B-it-Q5_K_M.gguf
CHAT_MMPROJ=mmproj-gemma-4-E4B-it-f16.gguf
CHAT_CTX_SIZE=8192

# llama.cpp embedding model (GGUF file in data/models/)
EMBED_MODEL=nomic-embed-text-v1.5.Q8_0.gguf
EMBED_CTX_SIZE=8192

# Qdrant collection name
QDRANT_COLLECTION=elfin_docs
